# Deployment Configuration
# Copy this file to deploy-config.env and fill in your server details
# This file should be added to .gitignore to protect your server information

# ═══════════════════════════════════════════════════════════════
# SSH Server Configuration
# ═══════════════════════════════════════════════════════════════
# Your server's IP address or hostname
DEPLOY_SERVER_IP=192.168.1.100

# SSH username for your server
DEPLOY_SERVER_USER=youruser

# Path where the bot will be deployed on the server
DEPLOY_SERVER_PATH=/home/youruser/ebay-bot

# ═══════════════════════════════════════════════════════════════
# Domain Configuration
# ═══════════════════════════════════════════════════════════════
# Your public domain name for the webhook
DEPLOY_DOMAIN=yourdomain.com

# Webhook endpoint URL (usually: https://yourdomain.com/webhook/ebay/notification)
DEPLOY_WEBHOOK_URL=https://yourdomain.com/webhook/ebay/notification

# ═══════════════════════════════════════════════════════════════
# Optional: SSH Configuration
# ═══════════════════════════════════════════════════════════════
# SSH port (default: 22)
# DEPLOY_SSH_PORT=22

# SSH key path (if using key-based authentication)
# DEPLOY_SSH_KEY_PATH=~/.ssh/id_rsa
